# UNLINK-TH SUPREME COMMAND CORE (V.3.0)
# .geminiignore - Sub-Project Specific Strategy Control

# 🚀 SYSTEM & DEPENDENCIES (KEEP AI CLEAN)
node_modules/
.next/
.vercel/
.git/
.turbo/
dist/
build/
*.log
*.tsbuildinfo
*.lock
package-lock.json
pnpm-lock.yaml
yarn.lock

# 🔐 SECURITY & SECRETS
.env*
*.local
secrets/
*.pem
*.key

# 🛠️ MEDIA & CACHE (SKIP HEAVY ASSETS)
public/images/
public/assets/
.cache/
tmp/
temp/

# 🛡️ ARCHITECTURAL BOUNDARY
# AI focus on Source, Config, and Documentation only.
!.gemini/
!GEMINI.md
!package.json
!tsconfig.json
!next.config.ts
!tailwind.config.mjs
