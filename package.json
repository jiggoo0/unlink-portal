{
  "name": "unlink-portal",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "next dev --webpack",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint app components lib constants --cache --max-warnings 0",
    "format": "prettier --write . --ignore-path .prettierignore",
    "type-check": "tsc --noEmit",
    "knip": "knip",
    "check": "pnpm run type-check",
    "aipc": "bash scripts/aipc.sh",
    "aisetup": "bash ../.gemini/bin/core/aisetup.sh",
    "modedev": "echo '[DEV_MODE] Activated - Enforcing Strict Rule Compliance' && cat ../.gemini/rules/DEV_MODE.md",
    "analyze": "ANALYZE=true next build",
    "audit:seo": "echo 'Checking JSON-LD & Metadata Integrity...' && grep -r 'JsonLd' app components && echo 'Structure verification complete.'",
    "db:ping": "tsx ../.gemini/domains/identity-farming/db/ping.ts",
    "db:migrate": "tsx ../.gemini/domains/identity-farming/db/migrate.ts",
    "ai:audit-unused": "bash ../.gemini/bin/core/audit-unused.sh",
    "ai:verify-precision": "tsx ../.gemini/bin/core/verify-precision.ts",
    "ai:content-guard": "tsx ../.gemini/bin/core/content-guard.ts",
    "ai:remove-emojis": "node ../.gemini/bin/core/remove_emojis.mjs"
  },
  "engines": {
    "node": ">=20.x"
  },
  "packageManager": "pnpm@9.15.4",
  "dependencies": {
    "@img/sharp-wasm32": "^0.34.5",
    "@line/bot-sdk": "^10.6.0",
    "@next/third-parties": "^16.1.6",
    "@radix-ui/react-accordion": "1.2.12",
    "@radix-ui/react-slot": "1.2.4",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.34.2",
    "googleapis": "^171.4.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.577.0",
    "next": "16.2.1",
    "next-mdx-remote": "^6.0.0",
    "next-themes": "^0.4.6",
    "nextjs-toploader": "^3.9.17",
    "postcss-load-config": "^6.0.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.9.3",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "4.2.1",
    "tailwindcss-animate": "^1.0.7",
    "vercel": "^50.37.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@next/eslint-plugin-next": "16.2.1",
    "@next/swc-android-arm64": "^13.2.4",
    "@next/swc-linux-arm64-musl": "^16.2.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/mdx": "^2.0.13",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "eslint": "^9.21.0",
    "eslint-plugin-react-hooks": "5.1.0",
    "globals": "^16.0.0",
    "knip": "^5.45.0",
    "postcss": "^8.5.3",
    "prettier": "^3.5.2",
    "schema-dts": "^1.1.2",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "typescript-eslint": "^8.25.0"
  }
}
